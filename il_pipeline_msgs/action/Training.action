# Goal: start a training job.

string dataset_id
string policy_type            # "bc" | "act" | "diffusion"
int32 epochs
int32 batch_size
float64 lr
int32 chunk_size
float64 validation_split
string device
---
# Result on completion.
bool success
string job_id
string best_checkpoint_path
float64 best_val_loss
string message
---
# Periodic feedback.
int32 epoch
int32 total_epochs
int32 step
float64 train_loss
float64 val_loss
float64 elapsed_s
